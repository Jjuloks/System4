
@{
    ViewData["Title"] = "Login";
}
<style>

    body {
        background: #F5F7FA;
    }


    .login-card {
        border-radius: 14px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1)5;
        border: none;
        max-width: 500px;
    }


    .profile-image-pic {
        border: none;
        background: #f1f5f9;
        padding: 10px;
        margin: auto;
        padding: 40px;
    }



    .form-control {
        border-radius: 10px;
        padding: 12px;
        font-size :1rem;
    }

    /* przycisk */

    .login-btn {
        width: 100%;
        border-radius: 10px;
        padding: 12px;
        font-size: 1rem;
        font-weight: 500;
    }

    /* odstęp od góry */

    .login-container {
        margin-top: 90px;
    }

</style>


<div class="container login-container">
<div class="row">
    <div class="col-md-4 offset-md-4">
        <h2 class="text-center text-dark mb-4">Login</h2>
            <div class="card login-card">

                <form class="card-body p-lg-5" asp-controller="Login" method="post" asp-action="Logowanie">

                <div class="text-center">
                        <img src="https://cdn.pixabay.com/photo/2023/02/18/11/00/icon-7797704_1280.png" class="img-fluid profile-image-pic img-thumbnail rounded-circle my-3"
                         width="200px" alt="profile">
                </div>

                <div class="mb-3">
                    <input type="text" class="form-control" name="login" 
                           placeholder="Login">
                </div>
                <div class="mb-3">
                    <input type="password" class="form-control" name="password" placeholder="Password">
                </div>
                <div class="text-center"><button type="submit" class="btn btn-primary login-btn">Login</button></div>
            </form>
                @if (ViewBag.Error != null)
                {
                     <div class="alert alert-danger" role="alert">
                    <p style="color:red">@ViewBag.Error</p>
                        </div>
                }
                   
        </>

    </div>
</div>
</div>
</div>



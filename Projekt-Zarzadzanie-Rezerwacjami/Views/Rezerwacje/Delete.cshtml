@model Projekt_Zarzadzanie_Rezerwacjami.Models.Rezerwacja

@{
    ViewData["Title"] = "Delete";
}
<style>
    .page-container {
        margin-top: 60px;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }

    h1 {
        text-align: center;
        margin-bottom: 30px;
        font-size: 2rem;
    }

    .form-container {
        width: 100%;
        max-width: 900px;
        background-color: #f5f7fa;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
    }
    .btn-back {
        background-color: #2563EB;
        color: white;
        padding: 10px 20px;
        font-size: 1rem;
        margin-top: 20px;
    }

    .btn-back:hover {
        background-color: #1D4ED8;
    }

    .row {
        margin-bottom: 10px;
        width :100%;
    }

    .col-sm-2 {
        display: flex;
        align-items: center;
    }

    .col-sm-10 {
        display: flex;
        align-items: center;
        justify-content: flex-start;
    }

</style>
<div class="page-container">
<h1>Delete</h1>
    <div class="form-container">
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ReservationDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ReservationDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Duration)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Duration)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EndReservationDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EndReservationDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Rozmiar)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Rozmiar)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sala)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sala)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> 
    </form>
        <a asp-action="Index" class="btn btn-back">Back to List</a>
        </div>
        </div>


@model Projekt_Zarzadzanie_Rezerwacjami.Models.TodayModel

@{
    ViewData["Title"] = "Today";
}
<style>
    .card-admin-tabela {
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        padding: 20px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .btn-table-edit {
        background-color: #2563EB;
        border: none;
        color: white;
        padding: 0.25rem 0.6rem;
        font-size: 0.85rem;
        height: auto;
        border-radius: 4px;
    }
    .btn-table-edit:hover {
        background: #1D4ED8;
    }

    .btn-table-delete {
        background: red;
        border: none;
        color: white;
        padding: 0.25rem 0.6rem;
        font-size: 0.85rem;
        height: auto;
        border-radius: 4px;
    }

    .btn-table-delete:hover {
         background: #B91C1C;
     }

    .table-container {
        background-color: #f5f7fa;
        border-radius: 10px;
    }

    .btn-info {
        background-color: #06B6D4;
        border: none;
        color: white;
    }

    .btn-primary-close {
        background: red;
        color: white;
        padding: 0.25rem 0.6rem;
        font-size: 0.85rem;
        height: auto;
        border-radius: 4px;
    }

    .btn-primary-close:hover {
        background: #B91C1C;
    }

    .btn-info:hover {
        background-color: #0891B2;
    }

    .table th, .table td {
        vertical-align: middle;
    }
</style>
<h1 class="text-center">Today</h1>


@if (Model.Rezerwacje.Count > 0)
{
    <div class="card card-admin-tabela">
        <div class="table-container">
            <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Id)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Name)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].ReservationDate)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Duration)
                                    </th>
                                      <th>@Html.DisplayNameFor(model => model.Rezerwacje[0].EndReservationDate)
                                    </th>  
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Rozmiar)
                                    </th>
                                        <th>@Html.DisplayNameFor(model => model.Rezerwacje[0].Sala) </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].IsExclusive)
                                    </th>
                        <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Rezerwacje)
                                {
                                    <tr>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Id)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Name)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.ReservationDate)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Duration)
                                        </td>
                                         <td>@Html.DisplayFor(modelItem => item.EndReservationDate)
                                         </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Rozmiar)
                                        </td>
                                        <td>
                                       @if (item.Room != null){
                 <button type="button" class="btn btn-sm btn-info">@item.Room.salaName</button>
             <button type="button" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#roomModal-@item.Id">
                <i class="fa-solid fa-circle-info"></i>ℹ️
             </button>
             }
             else
             {
             <span>-</span>
             }
             </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.IsExclusive)
                                        </td>
                                        <td>
                                            <a asp-controller="Rezerwacje" asp-action="Edit" asp-route-id="@item.Id" class="btn-table-edit">Edit</a> |
                                            <a asp-controller="Rezerwacje" asp-action="Delete" asp-route-id="@item.Id" class="btn-table-delete">Delete</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @foreach (var item in Model.Rezerwacje)
                        {
                            <div class="modal fade" id="roomModal-@item.Id" tabindex="-1" aria-labelledby="roomModalLabel-@item.Id" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="roomModalLabel-@item.Id">@item.Room?.salaName - Room Details</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            @if (item.Room != null && item.EndReservationDate != null)
                                            {
                                                 <p><strong>Room Capacity:</strong> @item.Room.Capacity</p>
                                                 <p><strong>Has tv :</strong> @(item.Room.HasTv ? "Yes" : "No")</p>
                                                 <p><strong>Reserved by</strong> @item.Name</p>
                                                 <p><strong>Reservation date</strong> @item.ReservationDate</p>
                                                 <p><strong>Duration</strong>  @Html.DisplayFor(modelItem => item.Duration)</p>
                                                 <p><strong>End Reservation date</strong> @item.EndReservationDate</p>
}
                                            else
                                            {
                                                <p>No info .</p>
                                            }
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-primary-close" data-bs-dismiss="modal">Close</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
}
else
{
    <p>No reservations for today.</p>
}

<a asp-controller="Rezerwacje" asp-action="Index" class="btn btn-primary btn-lg">Back</a>
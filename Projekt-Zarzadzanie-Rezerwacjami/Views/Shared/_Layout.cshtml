<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Login</title>
    <script type="importmap"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Projekt_Zarzadzanie_Rezerwacjami.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-dark custom-navbar">

            <div class="container position-relative justify-content-center">

                <a class="navbar-brand"
                   asp-controller="Login"
                   asp-action="Index">
                    Login
                </a>
                </div>
                </nav>
        <style>
        .custom-navbar {
            background: #1E293B;
            padding: 12px 0;
        }

        .custom-navbar .navbar-brand {
            color: white;
            font-weight: 600;
            font-size: 20px;
            margin: auto;
        }

        .logout-button {
            position: absolute;
            right: 20px;
            top: 10px;
            }

        header {
            background: #1E293B;
        }

        nav {
            background: #1E293B;
        }

        #navbar-brand {
            text-align: center;
        }

        .custom-footer {
            position: fixed;
            bottom: 0;
            width: 100%;
            background: #1E293B;
            color: #CBD5E1;
            padding: 10px;
            border-top: 1px solid #334155;
        }

        footer {
            bottom: 0;
            position: fixed;
            width: 100%;
            height: 60px;
            text-align: center;
            left: 0;
            background: #001F3F;
            color : white;
            border-top: 1px solid #1f2937;
            }

            .container text-center {
                margin-bottom: auto;
                margin-top: auto;
                text-align : center;
                vertical-align: central;
            }

        body {
            background: #F5F7FA;
        }

            .logout-button .btn-primary:hover {
                background-color: #dc3545 !important;
                border-color: #dc3545 !important;
            }
        </style>

        @{
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
            var isLoginPage = string.Equals(currentController, "Login", System.StringComparison.OrdinalIgnoreCase)
                              && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase);
        }

        @if (!isLoginPage)
        {
            <form method="get" action="/Login" class="logout-button">
                <button type="submit" class="btn btn-primary">Logout</button>
            </form>
        }
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="custom-footer">
        <div class="container text-center">
            &copy; 2026 - Reservation Management System
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

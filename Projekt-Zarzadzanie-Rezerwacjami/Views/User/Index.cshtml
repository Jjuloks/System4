@model IEnumerable<Projekt_Zarzadzanie_Rezerwacjami.Models.Rezerwacja>
@{
    ViewData["Title"] = "Strona usera";
}
<style>
#btnlogout {
    float: right;
    margin-top: -40px;
}
</style>
<h1 class="text-center">Panel Usera</h1>
<div class="row">
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-center align-items-center">
                    <h5 class="card-title">Zobacz rezerwacje na dzis</h5>
                </div>
                <div class="d-flex justify-content-center align-items-center">
                    <a asp-controller="User" asp-action="TodayU" class="btn btn-primary">Zobacz rezerwacje</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-center align-items-center">
                    <h5 class="card-title">Dodaj rezerwacje</h5>
                </div>
                <div class="d-flex justify-content-center align-items-center">
                    <a asp-action="Create" class="btn btn-primary">Dodaj rezerwacje</a>
                </div>
            </div>
        </div>
    </div>

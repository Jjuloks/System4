@model Projekt_Zarzadzanie_Rezerwacjami.Models.TodayModel

@{
    ViewData["Title"] = "Today";
}

<h1 class="text-center">Rezerwacje z dzis</h1>


@if (Model.Rezerwacje.Count > 0)
{
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card shadow-2-strong" style="background-color: #f5f7fa;">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Id)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Name)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].ReservationDate)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Duration)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Sala)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].Rozmiar)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Rezerwacje[0].IsExclusive)
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Rezerwacje)
                                {
                                    <tr>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Id)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Name)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.ReservationDate)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Duration)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Sala)
                                        </td>
                                        <td>
                                            @if (item.Room != null)
                                            {
                                                <button type="button" class="btn btn-sm btn-info">@item.Room.salaName</button>
                                                <button type="button" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#roomModal-@item.Id">
                                                    <i class="fa-solid fa-circle-info"></i>ℹ️
                                                </button>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Rozmiar)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.IsExclusive)
                                        </td>

                                    </tr>
                                }
                            </tbody>
                        </table>
                        @foreach (var item in Model.Rezerwacje)
                        {
                            <div class="modal fade" id="roomModal-@item.Id" tabindex="-1" aria-labelledby="roomModalLabel-@item.Id" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="roomModalLabel-@item.Id">Szczegóły sali - @item.Room?.salaName</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            @if (item.Room != null && item.EndReservationDate != null)
                                            {
                                                <p><strong>Rozmiar:</strong> @item.Room.Capacity</p>
                                                <p><strong>Czy ma TV:</strong> @(item.Room.HasTv ? "Tak" : "Nie")</p>
                                                <p><strong>Rezerwacja wybrana przez:</strong> @item.Name</p>
                                                <p><strong>Data rezerwacji:</strong> @item.ReservationDate</p>
                                                <p><strong>Rezerwacja na:</strong>  @Html.DisplayFor(modelItem => item.Duration)</p>
                                                <p><strong>Koniec rezerwacji:</strong> @item.EndReservationDate</p>
                                            }
                                            else
                                            {
                                                <p>Brak danych sali.</p>
                                            }
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Zamknij</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <p>No reservations for today.</p>
}

<a asp-controller="User" asp-action="Index" class="btn btn-primary btn-lg">Powrót</a>